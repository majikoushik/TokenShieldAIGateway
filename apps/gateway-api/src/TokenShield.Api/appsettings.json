{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=tokenshield;Username=postgres;Password=postgres"
  },
  "SeedDatabase": true,
  "ApplicationInsights": {
    "ConnectionString": ""
  },
  "OpenTelemetry": {
    "ServiceName": "tokenshield-gateway"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000"
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "RequestProfiler": {
    "Mode": "Mvp",
    "EnableProductionProfiler": false,
    "EnableSemanticClassifier": false,
    "EnableLlmClassifier": false,
    "LowConfidenceThreshold": 0.6,
    "HighConfidenceThreshold": 0.85,
    "DefaultTaskType": "general",
    "DefaultRiskLevel": "medium",
    "UseMetadataAsPrimarySignal": true,
    "ValidateMetadataAgainstPrompt": true,
    "EnableSensitivityDetection": true,
    "EnableProfileSignals": true,
    "TaskClassificationRules": [
      {
        "TaskType": "summarization",
