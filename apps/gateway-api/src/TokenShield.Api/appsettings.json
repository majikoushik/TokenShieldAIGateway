{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=tokenshield;Username=postgres;Password=postgres"
  },
  "SeedDatabase": true,
  "ApplicationInsights": {
    "ConnectionString": ""
  },
  "OpenTelemetry": {
    "ServiceName": "tokenshield-gateway"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000"
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
